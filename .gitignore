# --- BD y datos generados ---
data/*.db
data/fotos/
# Modelo multi-proyecto: BDs por proyecto + carpetas fotos/exports
data/proyectos/
data/_template.db
data/sistema.db
_adobe_extract_*/
_intermedio_*.xlsx
formato-hd-*.xlsx

# --- Carpeta de PDFs a ingestar (PDFs + metadata generada) ---
# El contenido es del cliente; no se versiona. La carpeta puede existir vacia.
indigest-pdf/

# --- Cotizaciones origen (PDFs/xlsx descargados) ---
# No versionar archivos de proveedores; son grandes y privados
*.pdf
*.xls
*.xlsx
*.xlsb
~$*

# Versionar fixtures de tests (sobrescribe los patrones de arriba)
!tests/fixtures/_intermedio_*.xlsx
!tests/fixtures/*.png

# Archivos descargados con nombres truncados (2026-XX__...)
2026-*
# Pero sí versionar los planes con fecha
!docs/plans/2026-*.md

# Permitir solo los .md y .txt informativos
!LEEME.txt
!PLAN_CONSOLIDADOS_POR_CATEGORIA.md

# --- Subcarpetas con datos brutos ---
Higiene/
rejas/

# --- Logs y exports ---
descarga_log.csv
*.csv

# --- Secretos ---
.env
credentials.json
token.json
threads_page*.json

# --- Python ---
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
venv/

# --- Editor ---
.vscode/
.idea/
.claude/
