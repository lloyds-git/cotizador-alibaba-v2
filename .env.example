# =============================================================
# .env.example -- copia este archivo a `.env` y rellena valores.
# El archivo `.env` está en .gitignore, no se versiona.
# =============================================================

# --- Adobe PDF Services ---
# Necesario para: extraer_pdf_adobe.py, pdf_a_formato_hd.py
# Obtén credenciales en: https://developer.adobe.com/document-services/
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# --- Anthropic Claude ---
# Necesario para: extraer_con_claude.py (extracción de productos desde PDFs)
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Opcional ---
# MAPEO: JSON con mapeo de columnas para llenar_formato_hd.py
# Alternativa a pasarlo por CLI. Ejemplo:
# MAPEO={"sku":"A","descripcion":"B","precio":"C"}
# MAPEO=

# --- Carpeta de PDFs/xlsx a ingestar ---
# Lugar donde dejas los archivos a procesar. Puede ser ruta relativa al proyecto
# o absoluta. Si no se setea, se usa "indigest-pdf" en la raiz del proyecto.
# Los artefactos intermedios (_adobe_extract_*, _intermedio_*.xlsx) se generan
# junto al PDF, dentro de esta misma carpeta.
PDF_INGEST_DIR=indigest-pdf

# --- Paths para el paso 4 de pdf_a_formato_hd.py (Excel COM, solo Windows) ---
# Si no se setean o las rutas no existen, el paso 4 se salta automaticamente
# (lo cual esta bien en Linux/Docker: el _intermedio_*.xlsx queda listo para ingestar).
SCRIPT_LLENAR_HD=
FORMATO_HD_PATH=

# Template del export Pet PD (Product Dimension). Si no se setea, la app
# busca "Pet PD Format.xlsx" en la raiz del proyecto.
FORMATO_PD_PATH=

# --- Auth Google OAuth2 ---
# Crea credenciales en https://console.cloud.google.com/apis/credentials
# Tipo: "OAuth client ID" -> "Web application"
# Authorized redirect URI: https://<tu-dominio>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://cotizav2.lloyds.com.mx/auth/callback

# Secret para firmar cookies de sesion. Generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Primer usuario autorizado. Se inserta al arrancar si la tabla esta vacia.
ADMIN_INICIAL=

# Dev/local sobre HTTP (sin TLS): poner 1 para que la cookie NO requiera HTTPS.
# En produccion (HTTPS) deja vacio o 0.
SESSION_INSECURE=0
