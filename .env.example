# =============================================================
# .env.example -- copia este archivo a `.env` y rellena valores.
# El archivo `.env` está en .gitignore, no se versiona.
# =============================================================

# --- Puerto de la app ---
# Puerto en el que se publica la app. Lo leen docker-compose.yml (puerto
# publicado en el host) y run-local.bat (uvicorn local). Cambia aqui y ambos
# lo toman. NOTA: Docker y run-local usan el MISMO puerto, asi que no corras
# los dos a la vez.
APP_PORT=8071

# --- Adobe PDF Services ---
# Necesario para: extraer_pdf_adobe.py, pdf_a_formato_hd.py
# Obtén credenciales en: https://developer.adobe.com/document-services/
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# --- Anthropic Claude ---
# Necesario para: extraer_con_claude.py (extracción de productos desde PDFs),
# búsqueda de competencia (app/competencia.py) y propuesta de catálogo con IA
# (app/catalogo_ia.py). Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Modelos de Claude (opcional; todos con default sensato) ---
# La app combina dos gamas: Haiku 4.5 (barato) para tareas perceptuales/de patrón
# y Sonnet 5 para lo que exige razonamiento. Descoméntalos solo si quieres cambiar;
# los valores mostrados SON los defaults actuales.
#
# Propuesta de catálogo con IA (app/catalogo_ia.py):
# CATALOGO_CATEGORIAS_MODELO=claude-haiku-4-5  # inferir dominio + categorías (barato)
# CATALOGO_ARANCELES_MODELO=claude-sonnet-5    # investigar fracción TIGIE + IGI% (precisión)
# CATALOGO_VISION_MODELO=claude-haiku-4-5      # describir/redescribir productos por foto
# CATALOGO_IA_MODELO=                          # (compat) fallback del modelo de categorías
# CATALOGO_WEBSEARCH_TOOL=                     # se autoselecciona por modelo; solo forzar si hace falta
# CATALOGO_MAX_BUSQUEDAS=18                    # tope de búsquedas web por lote de aranceles
# CATALOGO_ARANCEL_BATCH=8                     # categorías por llamada web_search (evita truncar el JSON)
# CATALOGO_MAX_DESCRIPCIONES=300              # muestra de descripciones enviada al modelo
# CATALOGO_CONFIANZA_MIN=0.5                  # confianza mínima para proponer una fracción
# CATALOGO_WEBSEARCH_DOMINIOS=                # csv opcional de dominios permitidos (vacío = sin límite)
#
# Búsqueda de competencia (app/competencia.py):
# COMPETENCIA_MODELO=claude-haiku-4-5          # buscar listings de competencia
# COMPETENCIA_WEBSEARCH_TOOL=                  # se autoselecciona por modelo
# COMPETENCIA_MAX_BUSQUEDAS=9                  # tope de búsquedas web por consulta
#
# NOTA: la server-tool web_search_20260209 (filtrado dinámico, mejor precisión) solo
# la soportan Sonnet 5 / 4.6 y Opus 4.6+. Haiku 4.5 da 400 con ella -> usa la básica
# 20250305. La versión se elige sola según el modelo, así que cambiar de modelo por
# env "solo funciona". (La extracción de PDF en extraer_con_claude.py usa Haiku 4.5.)

# --- Opcional ---
# MAPEO: JSON con mapeo de columnas para llenar_formato_hd.py
# Alternativa a pasarlo por CLI. Ejemplo:
# MAPEO={"sku":"A","descripcion":"B","precio":"C"}
# MAPEO=

# --- Carpeta de PDFs/xlsx a ingestar ---
# Lugar donde dejas los archivos a procesar. Puede ser ruta relativa al proyecto
# o absoluta. Si no se setea, se usa "indigest-pdf" en la raiz del proyecto.
# Los artefactos intermedios (_adobe_extract_*, _intermedio_*.xlsx) se generan
# junto al PDF, dentro de esta misma carpeta.
PDF_INGEST_DIR=indigest-pdf

# --- Paths para el paso 4 de pdf_a_formato_hd.py (Excel COM, solo Windows) ---
# Si no se setean o las rutas no existen, el paso 4 se salta automaticamente
# (lo cual esta bien en Linux/Docker: el _intermedio_*.xlsx queda listo para ingestar).
SCRIPT_LLENAR_HD=
FORMATO_HD_PATH=

# Template del export Pet PD (Product Dimension). Si no se setea, la app
# busca "Pet PD Format.xlsx" en la raiz del proyecto.
FORMATO_PD_PATH=

# --- Auth Google OAuth2 ---
# Crea credenciales en https://console.cloud.google.com/apis/credentials
# Tipo: "OAuth client ID" -> "Web application"
# Authorized redirect URI: https://<tu-dominio>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://cotizav2.lloyds.com.mx/auth/callback

# Secret para firmar cookies de sesion. Generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Primer usuario autorizado. Se inserta al arrancar si la tabla esta vacia.
ADMIN_INICIAL=

# Dev/local sobre HTTP (sin TLS): poner 1 para que la cookie NO requiera HTTPS.
# En produccion (HTTPS) deja vacio o 0.
SESSION_INSECURE=0
